# syntax=docker/dockerfile:1

# Backup CronJob image — contains PG client tools and cloud CLIs for
# pg_basebackup, pg_dump, and WAL upload to S3/GCS/SFTP/local.
#
# Multiple PG client versions are installed. The entrypoint script
# prepends the correct version's bin directory to PATH based on the
# PG_MAJOR env var (default: 17).
FROM alpine:3.23

RUN apk add --no-cache \
    ca-certificates tzdata bash curl \
    postgresql16-client \
    postgresql17-client \
    postgresql18-client \
    aws-cli \
    openssh-client \
    rclone \
    kubectl \
    && addgroup -S pgswarm \
    && adduser  -S pgswarm -G pgswarm

# pg-select-version.sh — sources in CronJob scripts to put the right
# PG client binaries on PATH.  Alpine installs versioned binaries
# under /usr/libexec/postgresql<major>/ and a default set under /usr/bin/.
COPY <<'EOF' /usr/local/bin/pg-select-version.sh
#!/bin/bash
# Usage: source pg-select-version.sh
# Reads PG_MAJOR from env (e.g. "16", "17") and prepends the matching
# bin dir to PATH so pg_basebackup/pg_dump resolve to the right version.
PG_MAJOR="${PG_MAJOR:-17}"
pg_versioned_dir="/usr/libexec/postgresql${PG_MAJOR}"
if [ -d "$pg_versioned_dir" ]; then
  export PATH="${pg_versioned_dir}:${PATH}"
fi
echo "Using PG client version: $(pg_dump --version | head -1)"
EOF
RUN chmod +x /usr/local/bin/pg-select-version.sh

USER pgswarm

ENTRYPOINT ["bash"]
