# syntax=docker/dockerfile:1

# в”Ђв”Ђ Build stage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
FROM --platform=$BUILDPLATFORM golang:1.26-alpine AS builder

# Injected by buildx for each platform in the matrix (linux/amd64, linux/arm64).
ARG TARGETOS
ARG TARGETARCH

RUN apk add --no-cache git ca-certificates tzdata postgresql-client

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -trimpath -ldflags="-s -w" \
    -o /out/satellite ./cmd/satellite

# в”Ђв”Ђ Runtime stage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Use a minimal base with pg_isready and pg_basebackup available (needed for
# health checks and replica bootstrap in Phase 3+).
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata postgresql17-client \
    && addgroup -S pgswarm \
    && adduser  -S pgswarm -G pgswarm

COPY --from=builder /out/satellite /usr/local/bin/satellite

USER pgswarm

ENTRYPOINT ["satellite"]
